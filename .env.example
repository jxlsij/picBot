TELEGRAM_BOT_TOKEN=123456:replace_me
# BOT_TOKEN=123456:replace_me

# Hugging Face webhook deploy:
# WEBHOOK_URL=https://username-spacename.hf.space
# TELEGRAM_API_URL=https://your-worker.workers.dev/bot{0}/{1}

# Optional tuning:
# EMOJI_COLUMNS=8
# MAX_EMOJIS=50
# PACK_TITLE=/
# Telegram does not allow bots to send custom emoji stickers as normal stickers.
# Keep this enabled so the bot sends a pack link after creating it.
# SEND_PACK_LINK=1
# PADDING_RATIO=0.04
# TRIM_TOLERANCE=18
# SHARPEN_AMOUNT=1.25
